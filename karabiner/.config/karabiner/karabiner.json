{
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Fix Corne volume keys (consumer → macOS system volume)",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "identifiers": [
                                            {
                                                "product_id": 1,
                                                "vendor_id": 18003
                                            }
                                        ],
                                        "type": "device_if"
                                    }
                                ],
                                "from": { "consumer_key_code": "volume_increment" },
                                "to": [{ "key_code": "volume_up" }],
                                "type": "basic"
                            },
                            {
                                "conditions": [
                                    {
                                        "identifiers": [
                                            {
                                                "product_id": 1,
                                                "vendor_id": 18003
                                            }
                                        ],
                                        "type": "device_if"
                                    }
                                ],
                                "from": { "consumer_key_code": "volume_decrement" },
                                "to": [{ "key_code": "volume_down" }],
                                "type": "basic"
                            },
                            {
                                "conditions": [
                                    {
                                        "identifiers": [
                                            {
                                                "product_id": 1,
                                                "vendor_id": 18003
                                            }
                                        ],
                                        "type": "device_if"
                                    }
                                ],
                                "from": { "consumer_key_code": "mute" },
                                "to": [{ "key_code": "mute" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Command+Backspace deletes previous word (except Finder)",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^com\\.apple\\.finder$"
                                        ],
                                        "type": "frontmost_application_unless"
                                    }
                                ],
                                "from": {
                                    "key_code": "delete_or_backspace",
                                    "modifiers": { "mandatory": ["command"] }
                                },
                                "to": [
                                    {
                                        "key_code": "delete_or_backspace",
                                        "modifiers": ["option"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Supr key acts as Command+Delete in Finder",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "bundle_identifiers": [
                                            "^com\\.apple\\.finder$"
                                        ],
                                        "type": "frontmost_application_if"
                                    }
                                ],
                                "from": {
                                    "key_code": "delete_forward",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    {
                                        "key_code": "delete_or_backspace",
                                        "modifiers": ["command"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Map Option+4 to tilde",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "4",
                                    "modifiers": {
                                        "mandatory": ["right_option"],
                                        "optional": ["any"]
                                    }
                                },
                                "to": [
                                    {
                                        "key_code": "semicolon",
                                        "modifiers": ["right_option"]
                                    }
                                ],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Swap left_command <-> left_control only on split keyboard unless in terminal apps",
                        "manipulators": [
                            {
                                "conditions": [
                                    {
                                        "identifiers": [
                                            {
                                                "product_id": 1,
                                                "vendor_id": 18003
