{
  "title": "Rules for Corne Split Keyboard",
  "rules": [
    {
      "description": "Swap left_command <-> left_control only on split keyboard unless in terminal apps",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "left_command",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "left_control"
            }
          ],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 18003,
                  "product_id": 1
                }
              ]
            },
            {
              "type": "frontmost_application_unless",
              "bundle_identifiers": [
                "^com\\.github\\.wez\\.wezterm$",
                "^com\\.apple\\.Terminal$",
                "^com\\.googlecode\\.iterm2$"
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "left_control",
            "modifiers": {
              "optional": [
                "any"
              ]
            }
          },
          "to": [
            {
              "key_code": "left_command"
            }
          ],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 18003,
                  "product_id": 1
                }
              ]
            },
            {
              "type": "frontmost_application_unless",
              "bundle_identifiers": [
                "^com\\.github\\.wez\\.wezterm$",
                "^com\\.apple\\.Terminal$",
                "^com\\.googlecode\\.iterm2$"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Fix Corne volume keys (consumer → macOS system volume)",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "consumer_key_code": "volume_increment"
          },
          "to": [
            {
              "key_code": "volume_up"
            }
          ],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 18003,
                  "product_id": 1
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "consumer_key_code": "volume_decrement"
          },
          "to": [
            {
              "key_code": "volume_down"
            }
          ],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 18003,
                  "product_id": 1
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "from": {
            "consumer_key_code": "mute"
          },
          "to": [
            {
              "key_code": "mute"
            }
          ],
          "conditions": [
            {
              "type": "device_if",
              "identifiers": [
                {
                  "vendor_id": 18003,
                  "product_id": 1
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
